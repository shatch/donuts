{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudFrontOACRead",
      "Effect": "Allow",
      "Principal": { "Service": "cloudfront.amazonaws.com" },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::donuts-hatch-org/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "DIST_ARN"
        }
      }
    }
  ]
}
